# 100xMoney Environment Configuration
# Copy this file to .env.local and fill in your values

# App URL (used for Stripe redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe - Monthly subscription payments
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PRICE_ID=price_your_monthly_plan_id

# Optional: OpenAI for AI Copilot (enhanced responses)
# OPENAI_API_KEY=sk-your_key_here

# Optional: Clerk for authentication
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key
# CLERK_SECRET_KEY=sk_test_your_key
